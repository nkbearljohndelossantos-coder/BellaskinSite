# Required when building the Vite site (for example: npm run build).
# Values prefixed with VITE_ are embedded in the browser bundle at build time.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Do not use a VITE_ variable for real admin authentication secrets.
# Move admin authentication to a server-side or Supabase Auth flow before production.
